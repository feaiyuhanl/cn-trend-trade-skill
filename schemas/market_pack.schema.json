{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cn-trend-trade-skill/schemas/market_pack.schema.json",
  "title": "MarketPack",
  "type": "object",
  "required": ["meta", "symbols", "indices", "user_context"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["run_id", "as_of", "fetch_status", "skill_version", "mode"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "as_of": { "type": "string", "minLength": 1 },
        "fetch_status": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["ok", "fail", "skip", "not_configured"]
          }
        },
        "skill_version": { "type": "string" },
        "mode": { "type": "string", "enum": ["live", "fixture", "mixed"] },
        "symbols_requested": {
          "type": "array",
          "items": { "type": "string" }
        },
        "indices_profile": { "type": "string" }
      }
    },
    "symbols": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instrument" }
    },
    "indices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instrument" }
    },
    "user_context": { "$ref": "#/$defs/user_context" },
    "market_breadth": {
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/breadth_snapshot" }
    }
  },
  "$defs": {
    "instrument": {
      "type": "object",
      "required": ["ts_code", "name", "asset_type", "bars"],
      "properties": {
        "ts_code": { "type": "string" },
        "name": { "type": "string" },
        "asset_type": { "type": "string", "enum": ["stock", "index"] },
        "category": { "type": "string" },
        "index_group": { "type": "string" },
        "bars": {
          "type": "object",
          "required": ["daily", "weekly", "monthly"],
          "properties": {
            "daily": { "type": "array", "items": { "$ref": "#/$defs/bar" } },
            "weekly": { "type": "array", "items": { "$ref": "#/$defs/bar" } },
            "monthly": { "type": "array", "items": { "$ref": "#/$defs/bar" } }
          }
        },
        "derived_hints": { "type": "object" }
      }
    },
    "bar": {
      "type": "object",
      "required": ["id", "trade_date", "open", "high", "low", "close", "pct_chg", "vol"],
      "properties": {
        "id": { "type": "string" },
        "trade_date": { "type": "string" },
        "open": { "type": "number" },
        "high": { "type": "number" },
        "low": { "type": "number" },
        "close": { "type": "number" },
        "pct_chg": { "type": "number" },
        "vol": { "type": ["number", "null"] },
        "amount": { "type": ["number", "null"] },
        "source_id": { "type": "string" }
      }
    },
    "user_context": {
      "type": "object",
      "required": ["session_mode"],
      "properties": {
        "session_mode": {
          "type": "string",
          "enum": ["new_entry", "holdings_review", "mixed"]
        },
        "portfolio": {
          "type": "object",
          "properties": {
            "total_equity": { "type": "number" },
            "risk_per_trade_pct": { "type": "number" },
            "max_single_position_pct": { "type": "number" },
            "max_total_exposure_pct": { "type": "number" }
          }
        },
        "positions": {
          "type": "array",
          "items": { "$ref": "#/$defs/position" }
        },
        "user_notes": { "type": "string" }
      }
    },
    "position": {
      "type": "object",
      "required": ["ts_code"],
      "properties": {
        "ts_code": { "type": "string" },
        "cost": { "type": "number" },
        "shares": { "type": "number" },
        "entry_date": { "type": "string" },
        "stop_price": { "type": "number" },
        "notes": { "type": "string" }
      }
    },
    "breadth_snapshot": {
      "type": "object",
      "required": ["id", "trade_date"],
      "properties": {
        "id": { "type": "string" },
        "trade_date": { "type": "string" },
        "advance": { "type": ["integer", "null"] },
        "decline": { "type": ["integer", "null"] },
        "limit_up": { "type": ["integer", "null"] },
        "limit_down": { "type": ["integer", "null"] },
        "source_id": { "type": "string" }
      }
    }
  }
}
